      "end": 1721.54,
      "text": "תודה רבה."
    },
    {
      "start": 1750.52,
      "end": 1751.54,
      "text": "תודה רבה."
    },
    {
      "start": 1780.52,
      "end": 1781.54,
      "text": "תודה רבה."
    },
    {
      "start": 1810.54,
      "end": 1818.54,
      "text": "מזמינה אותנו"
    },
    {
      "start": 1821.78,
      "end": 1823.28,
      "text": "להעלות בדמיוננו"
    },
    {
      "start": 1825.26,
      "end": 1826.1399999999999,
      "text": "מישהו יקר"
    },
    {
      "start": 1827.6,
      "end": 1828.3,
      "text": "או יקרה"
    },
    {
      "start": 1831.0,
      "end": 1833.84,
      "text": "שהיינו רוצים לשלוח לה או לא הרבה הרבה טוב."
    },
    {
      "start": 1834.0400000000002,
      "end": 1843.46,
      "text": "טוב. אפשר להושיב אותה או אותו לשבת מולנו"
    },
    {
      "start": 1844.5000000000002,
      "end": 1845.4,
      "text": "או לצידנו."
    },
    {
      "start": 1854.66,
      "end": 1858.6000000000001,
      "text": "לתת ללב שלנו לשלוח את"
    },
    {
      "start": 1860.42,
      "end": 1861.5000000000002,
      "text": "המילים הטובות."
    },
    {
      "start": 1863.8600000000001,
      "end": 1879.16,
      "text": "הלוואי שתהיה לך או לך הרבה טוב."
    },
    {
      "start": 1887.5200000000002,
      "end": 1891.3600000000001,
      "text": "הלוואי שתחי או תחיה בהרבה שמחה."
    },
    {
      "start": 1893.8400000000001,
      "end": 1896.8600000000001,
      "text": "לרווחה."
    },
    {
      "start": 1923.8400000000001,
      "end": 1950.94,
      "text": "אפשר להגיד,"
    },
    {
      "start": 1950.96,
      "end": 1955.04,
      "text": "לאדם היקר או ליקרה שלום."
    },
    {
      "start": 1958.6200000000001,
      "end": 1960.8600000000001,
      "text": "ולהפנות את המתה כלפי עצמנו."
    },
    {
      "start": 1970.64,
      "end": 1971.76,
      "text": "הלוואי שיהיה לי טוב."
    },
    {
      "start": 1981.76,
      "end": 1984.76,
      "text": "שיחיה בשמחה, ברווחה."
    },
    {
      "start": 1998.48,
      "end": 2000.68,
      "text": "הלוואי שהלב שלי יישאר פתוח"
    },
    {
      "start": 2002.48,
      "end": 2003.02,
      "text": "ורך"
    },
    {
      "start": 2004.3,
      "end": 2004.98,
      "text": "ומרווח."
    },
    {
      "start": 2010.94,
      "end": 2013.66,
      "text": "אפשר לנשום מתוך הלב לכל הגוף."
    },
    {
      "start": 2040.94,
      "end": 2070.92,
      "text": "תודה רבה."
    },
    {
      "start": 2070.94,
      "end": 2071.94,
      "text": "תודה רבה."
    },
    {
      "start": 2100.96,
      "end": 2110.62,
      "text": "מזמינה אותנו לאיכות של השמחה"
    },
    {
      "start": 2112.58,
      "end": 2114.42,
      "text": "על האפשרות לאמן את הלב להיפתח."
    },
    {
      "start": 2117.4,
      "end": 2118.32,
      "text": "כל פעם עוד קצת."
    },
    {
      "start": 2128.32,
      "end": 2130.84,
      "text": "שמחה לשבת עם הרבה לבבות."
    },
    {
      "start": 2130.96,
      "end": 2134.04,
      "text": "שרוצים טוב."
    },
    {
      "start": 2136.9,
      "end": 2143.94,
      "text": "זה ממש להיפתח לתחושה המשותפת של הישיבה המיטיבה כאן."
    },
    {
      "start": 2147.14,
      "end": 2147.84,
      "text": "כמה לבבות."
    },
    {
      "start": 2150.2000000000003,
      "end": 2151.48,
      "text": "כמה כוונות מיטיבות."
    },
    {
      "start": 2160.94,
      "end": 2161.04,
      "text": "תודה רבה."
    },
    {
      "start": 2190.96,
      "end": 2206.92,
      "text": "אפשר להמשיך עם הכוונה הזו של הלב לתוך תרגול בהליכה או להישאר לתרגול בעמידה."
    },
    {
      "start": 2206.92,
      "end": 2228.32,
      "text": "אפשר לצאת החוצה ולחוש איך הברכות של המתה שנאמרות בכל מיני מקומות בעולם"
    },
    {
      "start": 2230.04,
      "end": 2231.42,
      "text": "נוחתות אצלנו בלב."
    },
    {
      "start": 2234.14,
      "end": 2235.96,
      "text": "תחשבו כמה אנשים ונשים"
    },
    {
      "start": 2237.46,
      "end": 2240.36,
      "text": "שולחים את האיחולי המתה."
    },
    {
      "start": 2240.88,
      "end": 2243.02,
      "text": "שכל האיחולים והאיחולות"
    },
    {
      "start": 2244.04,
      "end": 2246.12,
      "text": "יחיו ברווחה ובשמחה."
    },
    {
      "start": 2248.08,
      "end": 2249.7000000000003,
      "text": "גם אנחנו יצורים ואיחולות."
    },
    {
      "start": 2252.96,
      "end": 2256.28,
      "text": "אפשר לתת לאיחולים האלה להיכנס אלינו ללב."
    },
    {
      "start": 2258.06,
      "end": 2259.36,
      "text": "אפשר להעביר אותם הלאה."
    },
    {
      "start": 2262.36,
      "end": 2263.26,
      "text": "לקבל ולתת."
    },
